# Copy to .env and fill in.
# Get an Application ID from https://discord.com/developers/applications
# -> your app -> General Information.
DISCORD_CLIENT_ID=

# Where to look for git repos. The app scans this folder, finds every .git,
# and sums total commits across all of them. Default is your home folder.
# Leave blank to use the default.
REPO_ROOT=

# Advanced: comma-separated list of specific repos to track. Overrides
# REPO_ROOT if set. Example:
#   REPO_PATHS=/home/me/project-a,/home/me/project-b
REPO_PATHS=

# Asset key uploaded under Rich Presence -> Art Assets.
LARGE_IMAGE_KEY=logo

# Update interval in seconds. Discord rate-limits to one update per 15s.
UPDATE_INTERVAL=15

# Hide the presence when no Claude transcript has been written in this many
# seconds. 300 = 5 minutes. Prevents the icon lingering while you play games
# or browse the web.
IDLE_SECONDS=300

# Base seconds between vibe changes. Actual hold is randomized between
# 0.5x and 2x this, so the rotation feels organic instead of metronomic.
VIBE_ROTATION=120
